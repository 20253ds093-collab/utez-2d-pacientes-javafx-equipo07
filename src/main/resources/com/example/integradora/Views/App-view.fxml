<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.integradora.Controllers.AppController">
    <children>
        <HBox spacing="20.0">
            <children>
                <Label fx:id="lblTotal" text="Total: 0" style="-fx-font-weight: bold;" />
                <Label fx:id="lblActivos" text="Activos: 0" style="-fx-font-weight: bold; -fx-text-fill: green;" />
                <Label fx:id="lblInactivos" text="Inactivos: 0" style="-fx-font-weight: bold; -fx-text-fill: gray;" />
            </children>
        </HBox>

        <HBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="5.0" prefWidth="200.0">
                    <children>
                        <TextField fx:id="txtCurp" promptText="CURP" />
                        <TextField fx:id="txtNombre" promptText="Nombre" />
                        <TextField fx:id="txtEdad" promptText="Edad" />
                        <TextField fx:id="txtTelefono" promptText="Teléfono" />
                        <TextArea fx:id="txtAlergias" prefHeight="50.0" promptText="Alergias" />
                        <ComboBox fx:id="cbEstatus" maxWidth="Infinity" />

                        <Button fx:id="btnGuardar" maxWidth="Infinity" onAction="#onGuardar" text="Guardar" />
                        <Button maxWidth="Infinity" onAction="#onNuevo" text="Limpiar" />

                        <Label fx:id="lblMsg" wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <TableView fx:id="tblPacientes" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colCurp" prefWidth="90.0" text="CURP" />
                                <TableColumn fx:id="colNombre" prefWidth="130.0" text="Nombre" />
                                <TableColumn fx:id="colEdad" prefWidth="40.0" text="E" />
                                <TableColumn fx:id="colTelefono" prefWidth="90.0" text="Tel" />
                                <TableColumn fx:id="colEstatus" prefWidth="70.0" text="Estatus" />
                            </columns>
                        </TableView>

                        <HBox spacing="10.0">
                            <children>
                                <Button onAction="#onEliminar" text="Eliminar" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</VBox>